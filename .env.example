YANGO_TOKEN_COFIX=
YANGO_TOKEN_SHUFERSAL=
YANGO_TOKEN_APLI_TAXI_OZ=
# Optional: separate B2B token for TEST CABINET (defaults to YANGO_TOKEN_APLI_TAXI_OZ)
YANGO_TOKEN_TEST_CABINET=
YANGO_TOKEN_SHANA10=
YANGO_TOKEN_TEL_AVIV_MUNICIPALITY=
YANGO_TOKEN_YANGO_DELI=
YANGO_TOKEN_SHLAV=
YANGO_TOKEN_SAMLET_MOTORS=
YANGO_TOKEN_HAMOSHAVA_20=
YANGO_TOKEN_STAR_TAXI_POINT=
YANGO_TOKEN_OPTICITY=
# Optional: override B2B paths if your tenant differs (defaults: /2.0/orders/create, /2.0/orders/cancel)
# YANGO_CREATE_ORDER_ENDPOINT=
# YANGO_CANCEL_ORDER_ENDPOINT=
# B2B /2.0/orders/list window for Dashboard + Orders (defaults: 90 days back, 90 days ahead)
# YANGO_B2B_ORDERS_LIST_SINCE_DAYS=90
# YANGO_B2B_ORDERS_LIST_TILL_DAYS_AHEAD=90
# Request Rides: GET /2.0/users employee list (pagination; user_id = item.id)
# YANGO_USER_LIST_PAGE_SIZE=100
# YANGO_USER_LIST_MAX_PAGES_SEARCH=25
# YANGO_USER_LIST_MAX_PAGES_RESOLVE=50
# Orders page: list chunk size per cabinet per wave (default 80)
# YANGO_B2B_ORDERS_CHUNK_LIST_LIMIT=80
# Route preview map backend (default: public OSRM server)
# OSRM_BASE_URL=https://router.project-osrm.org
# ROUTE_PROVIDER_TIMEOUT_MS=5000
# Google Routes API v2: route preview on map (km, ETA, leg coloring) + traffic-aware order optimization. When unset, preview uses OSRM; optimize UI/bulk skip Google.
# GOOGLE_MAPS_API_KEY=
# Optional custom tile URL for client map preview
# NEXT_PUBLIC_OSM_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# Request Rides map: MapLibre vector style (defaults to CARTO Positron). For MapTiler/Google-like tiles set your style URL + key.
# NEXT_PUBLIC_MAPLIBRE_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_KEY
ENABLE_LOCAL_GREENPLUM_SYNC=false
ENABLE_REMOTE_GREENPLUM_SYNC_REQUESTS=false
GREENPLUM_SYNC_REQUESTED_BY=notes-dashboard
SYNC_REQUEST_POLL_MS=15000
SYNC_REQUEST_WORKER_ID=local-vpn-worker
GREENPLUM_SYNC_COMMAND=npm run sync:datagrip:run
DATAGRIP_CONNECTION_CHECK_COMMAND=npm run sync:datagrip:check
DATAGRIP_SYNC_COMMAND=npm run sync:datagrip:run
DATAGRIP_VALIDATE_COMMAND=npm run sync:datagrip:validate
B2B_SYNC_INITIAL_FROM=2026-01-01T00:00:00Z
B2B_SYNC_OVERLAP_HOURS=2
FCT_FORCE_FROM_TS=
FCT_FORCE_TO_TS=
B2B_BACKFILL_FROM=2022-01-01T00:00:00Z
B2B_BACKFILL_TO=
B2B_BACKFILL_WINDOW_DAYS=7
B2B_CREATED_SYNC_WINDOW_DAYS=3
DATAGRIP_DATASOURCES_HISTORY_PATH=
DATAGRIP_DATASOURCE_UUID=
GREENPLUM_PASSWORD=
GREENPLUM_SSL_MODE=require
ENABLE_SYNC_AGG_EXECUTOR=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Inforu SMS (Request Rides: stop/destination passengers). Ride creation works without these; SMS is skipped until set.
INFORU_USERNAME=
INFORU_API_TOKEN=
# Sender ID as approved in Inforu (Hebrew/latin per your account). Optional; defaults to AppliTaxi in code if empty.
INFORU_SENDER=
# Optional WhatsApp (same Inforu account; template must be approved — see README + https://apidoc.inforu.co.il/)
# INFORU_WHATSAPP_TEMPLATE_ID=
# INFORU_WHATSAPP_BODY_PLACEHOLDER=[#1#]
