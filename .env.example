# --- Local: Vercel "Development" env (secrets injected at runtime; use when env:pull leaves YANGO_* empty) ---
# One-time: npx vercel link
# Then: npm run dev:vercel   (wraps Next; same env layer as Vercel Development, not git branch develop)
# --- Full parity with Vercel Production (Supabase + Yango + KV) ---
# One-time: npx vercel link
# Then: npm run env:pull:production
# If pull leaves empty Supabase / Yango tokens: npm run env:merge-from-backup (needs .env.local.bak.* from before pull, or pass path as CLI arg)
# (Back up .env.local first; the pull overwrites the file. Re-add any laptop-only lines after.)
# Do NOT set YANGO_TOKEN_REGISTRY_PRECEDENCE=env if you want the same token merge as production (default: registry/KV wins over duplicate env).
# ---

YANGO_TOKEN_COFIX=
YANGO_TOKEN_SHUFERSAL=
YANGO_TOKEN_APLI_TAXI_OZ=
# Optional: separate B2B token for TEST CABINET (defaults to YANGO_TOKEN_APLI_TAXI_OZ)
YANGO_TOKEN_TEST_CABINET=
YANGO_TOKEN_SHANA10=
YANGO_TOKEN_TEL_AVIV_MUNICIPALITY=
YANGO_TOKEN_YANGO_DELI=
YANGO_TOKEN_SHLAV=
YANGO_TOKEN_SAMLET_MOTORS=
YANGO_TOKEN_HAMOSHAVA_20=
YANGO_TOKEN_STAR_TAXI_POINT=
YANGO_TOKEN_OPTICITY=
YANGO_TOKEN_ZHAK=
YANGO_TOKEN_VIP_LUX_TRAVEL=
YANGO_TOKEN_IFA=
# Optional: JSON map of Yango park client_id -> cost center id (deploy pin when discovery is insufficient)
# YANGO_PINNED_COST_CENTER_JSON={"example-client-id":"example-cost-center-uuid"}
# Optional: omit = prod parity (KV wins over duplicate env). Set env only to force .env.local over KV everywhere:
# YANGO_TOKEN_REGISTRY_PRECEDENCE=env
# Local next dev only (VERCEL unset): non-empty YANGO_TOKEN_* wins over stale KV until you run npm run sync:yango-tokens-to-kv
# YANGO_TOKEN_LOCAL_PREFER_ENV=true
# Optional: override B2B paths if your tenant differs (defaults: /2.0/orders/create, /2.0/orders/cancel)
# YANGO_CREATE_ORDER_ENDPOINT=
# YANGO_CANCEL_ORDER_ENDPOINT=
# B2B /2.0/orders/list window for Dashboard + Orders (defaults: 90 days back, 90 days ahead)
# YANGO_B2B_ORDERS_LIST_SINCE_DAYS=90
# YANGO_B2B_ORDERS_LIST_TILL_DAYS_AHEAD=90
# Request Rides: GET /2.0/users employee list (pagination; user_id = item.id)
# YANGO_USER_LIST_PAGE_SIZE=100
# YANGO_USER_LIST_MAX_PAGES_SEARCH=25
# YANGO_USER_LIST_MAX_PAGES_RESOLVE=50
# Orders page: list chunk size per cabinet per wave (default 80)
# YANGO_B2B_ORDERS_CHUNK_LIST_LIMIT=80
# Route preview map backend (default: public OSRM server)
# OSRM_BASE_URL=https://router.project-osrm.org
# ROUTE_PROVIDER_TIMEOUT_MS=5000
# Address suggest provider for `/api/address-suggest`: osm (default) | govmap.
# GEOCODING_SUGGEST_PROVIDER=govmap
# GovMap suggest PoC (optional): if empty, code falls back to OSM/Nominatim.
# GOVMAP_SUGGEST_BASE_URL=https://api.govmap.gov.il
# GOVMAP_SUGGEST_PATH=/api/search
# GOVMAP_API_KEY=
# Google Routes API v2 + Geocoding API (JSON): Request Rides route preview + optimization + Price Calculator Transcripts (same key). Enable Geocoding API + Routes API on GCP. When unset, preview uses OSRM; optimize UI/bulk skip Google; Transcripts returns 503.
# GOOGLE_MAPS_API_KEY=
# Optional: delay (ms) before Nominatim fallback per address when Google returns no result (default 1100; respect OSM rate limits).
# TRANSCRIPT_NOMINATIM_DELAY_MS=1100
# Optional custom tile URL for client map preview
# NEXT_PUBLIC_OSM_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# Request Rides map: MapLibre vector style (defaults to CARTO Positron). For MapTiler/Google-like tiles set your style URL + key.
# NEXT_PUBLIC_MAPLIBRE_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_KEY
ENABLE_LOCAL_GREENPLUM_SYNC=false
ENABLE_REMOTE_GREENPLUM_SYNC_REQUESTS=false
GREENPLUM_SYNC_REQUESTED_BY=notes-dashboard
SYNC_REQUEST_POLL_MS=15000
SYNC_REQUEST_WORKER_ID=local-vpn-worker
GREENPLUM_SYNC_COMMAND=npm run sync:datagrip:run
DATAGRIP_CONNECTION_CHECK_COMMAND=npm run sync:datagrip:check
DATAGRIP_SYNC_COMMAND=npm run sync:datagrip:run
DATAGRIP_VALIDATE_COMMAND=npm run sync:datagrip:validate
B2B_SYNC_INITIAL_FROM=2026-01-01T00:00:00Z
B2B_SYNC_OVERLAP_HOURS=2
FCT_FORCE_FROM_TS=
FCT_FORCE_TO_TS=
B2B_BACKFILL_FROM=2022-01-01T00:00:00Z
B2B_BACKFILL_TO=
B2B_BACKFILL_WINDOW_DAYS=7
B2B_CREATED_SYNC_WINDOW_DAYS=3
DATAGRIP_DATASOURCES_HISTORY_PATH=
DATAGRIP_DATASOURCE_UUID=
GREENPLUM_PASSWORD=
GREENPLUM_SSL_MODE=require
ENABLE_SYNC_AGG_EXECUTOR=false
NEXT_PUBLIC_SUPABASE_URL=
# Optional: direct Postgres URL for schema migrations (Supabase → Settings → Database → Connection string)
SUPABASE_DB_URL=
# Or database password + project URL (script builds db.<ref>.supabase.co connection)
SUPABASE_DB_PASSWORD=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Authentication: Google Workspace SSO (@appli.taxi only) ---
# OAuth 2.0 Web client from Google Cloud Console (same org as appli.taxi).
# Consent screen must be "Internal" so only appli.taxi org users can sign in.
# Authorized redirect URIs must include: https://<prod-domain>/api/auth/google/callback
# and http://localhost:3000/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: override the callback URL (defaults to <request-origin>/api/auth/google/callback).
# GOOGLE_OAUTH_REDIRECT_URI=
# Workspace domain allowed to sign in (defaults to appli.taxi).
GOOGLE_WORKSPACE_DOMAIN=appli.taxi
# Secret used to sign the session cookie (crm_session_v1). Use a long random string.
# Falls back to SUPABASE_SERVICE_ROLE_KEY / KV_REST_API_TOKEN if unset.
AUTH_SESSION_SECRET=
# Inforu SMS (Request Rides: stop/destination passengers). Ride creation works without these.
INFORU_USERNAME=
INFORU_API_TOKEN=
# Set to true/1/yes only after Inforu approves API send; then redeploy (Vercel) or restart dev.
# INFORU_SMS_ENABLED=true
# Sender ID as approved in Inforu (Hebrew/latin per your account). Optional; defaults to AppliTaxi in code if empty.
INFORU_SENDER=

# --- OpenAI (Tariff Health Check; Price Calculator → Transcripts → Total decoupling % suggestions) ---
# Chat Completions API. Copy these lines to .env.local (never commit .env.local) and set OPENAI_API_KEY.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1-mini
# Optional (Tariff Health chat + structured JSON e.g. Transcripts decoupling suggestions — same max_tokens):
# OPENAI_TARIFF_ANALYSIS_TIMEOUT_MS=90000
# OPENAI_TARIFF_ANALYSIS_MAX_TOKENS=4096
# If JSON suggestions fail with “truncated”, try 8192.
# OPENAI_TARIFF_ANALYSIS_TEMPERATURE=0.35

# --- Sales Operation: WPForms webhook (Uncanny Automator → Pipeline) ---
# Long random secret; same value in Automator Webhooks action header X-Webhook-Secret.
# SALES_OPERATION_WPFORMS_WEBHOOK_SECRET=

# --- Sales Operation: outbound email (Phase 10) ---
# SMTP relay for sending lead emails. Works with Google Workspace (SMTP relay / app password)
# and Microsoft 365 (smtp.office365.com, SMTP AUTH enabled). Leave empty to disable sending
# (composer still records drafts to the thread; nothing is sent).
# SALES_SMTP_HOST=smtp.gmail.com
# SALES_SMTP_PORT=587
# SALES_SMTP_SECURE=false            # true for port 465, false for 587 (STARTTLS)
# SALES_SMTP_USER=sales@yourdomain.com
# SALES_SMTP_PASSWORD=
# From header for outgoing mail (defaults to SALES_SMTP_USER). Example: "Sales <sales@yourdomain.com>"
# SALES_SMTP_FROM=
# Inbound email webhook secret (parse service posts to /api/sales-operation/email/inbound).
# SALES_EMAIL_INBOUND_SECRET=
